---
import Layout from '../layouts/Layout.astro';
import UploadModal from '../components/UploadModal.astro';
---

<Layout>

  <!-- Skip to main (WCAG 2.4.1) -->
  <a href="#main-content" class="skip-link">본문으로 건너뛰기</a>

  <!-- ─── Navigation ──────────────────────────────── -->
  <header class="nav" id="nav" role="banner">
    <div class="container nav__inner">
      <a href="/" class="nav__logo" aria-label="PolyInsight 홈">
        Poly<span>Insight</span>
      </a>

      <nav class="nav__links" aria-label="주요 메뉴">
        <a href="#how-it-works">작동 방식</a>
        <a href="#features">주요 기능</a>
      </nav>

      <div class="nav__actions">
        <a href="#" class="btn btn-ghost btn-login">로그인</a>
        <a href="#signup" class="btn btn-primary" data-open-modal>무료로 시작하기</a>
      </div>

      <button
        class="nav__toggle"
        aria-label="메뉴 열기"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
          <line x1="3" y1="6"  x2="19" y2="6"  stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
          <line x1="3" y1="11" x2="19" y2="11" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
          <line x1="3" y1="16" x2="13" y2="16" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <!-- Mobile nav drawer -->
    <div class="nav__mobile" id="mobile-nav" aria-hidden="true">
      <nav aria-label="모바일 메뉴">
        <a href="#how-it-works">작동 방식</a>
        <a href="#features">주요 기능</a>
        <a href="#" class="mobile-login">로그인</a>
      </nav>
      <a href="#signup" class="btn btn-primary" style="width:100%; justify-content:center;" data-open-modal>무료로 시작하기</a>
    </div>
  </header>

  <main id="main-content">

    <!-- ─── Hero ─────────────────────────────────────── -->
    <section class="hero" aria-labelledby="hero-title">
      <div class="container hero__grid">

        <div class="hero__content">
          <p class="eyebrow">무료 베타 운영 중</p>
          <h1 id="hero-title" class="hero__title">
            논문 PDF 하나로,<br>카드뉴스 완성
          </h1>
          <p class="hero__sub">
            학술 논문을 업로드하면 AI가 원문에서 핵심 내용을 직접 추출해 카드뉴스를 만듭니다.
            수치와 근거는 논문 그대로, 편집 가능한 형태로 제공됩니다.
          </p>
          <div class="hero__actions">
            <a href="#signup" class="btn btn-primary btn-lg" data-open-modal>무료로 시작하기</a>
            <p class="hero__note">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.25"/>
                <path d="M4.5 7l2 2 3-3.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              회원가입 없이 바로 사용 가능
            </p>
          </div>
        </div>

        <!-- Product visual: stacked card output mockup -->
        <div class="hero__visual" aria-hidden="true">
          <div class="card-stack">
            <!-- Card 3 (back) -->
            <div class="card-mock card-mock--3">
              <div class="card-mock__header">
                <span>서론</span><span>1 / 8</span>
              </div>
            </div>
            <!-- Card 2 (middle) -->
            <div class="card-mock card-mock--2">
              <div class="card-mock__header">
                <span>연구 방법</span><span>3 / 8</span>
              </div>
              <div class="card-mock__body">
                <div class="mock-line mock-line--title"></div>
                <div class="mock-line"></div>
                <div class="mock-line mock-line--short"></div>
              </div>
            </div>
            <!-- Card 1 (front) -->
            <div class="card-mock card-mock--1">
              <div class="card-mock__header">
                <span>연구 결과</span><span>4 / 8</span>
              </div>
              <div class="card-mock__body">
                <p class="card-mock__stat">73.2%</p>
                <p class="card-mock__claim">전체 샘플에서 통계적 유의성 확인</p>
                <div class="card-mock__cite">
                  <svg width="11" height="11" viewBox="0 0 11 11" fill="none">
                    <rect x="1" y="1" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.1"/>
                    <line x1="3" y1="4" x2="8" y2="4" stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/>
                    <line x1="3" y1="6" x2="6.5" y2="6" stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/>
                  </svg>
                  Table 2, p.8
                </div>
              </div>
            </div>
          </div>

          <!-- Input label -->
          <div class="visual-label visual-label--input">
            <svg width="28" height="36" viewBox="0 0 28 36" fill="none" aria-hidden="true">
              <rect x="1" y="1" width="26" height="34" rx="3" fill="white" stroke="var(--border)" stroke-width="1.5"/>
              <rect x="5" y="8" width="12" height="2" rx="1" fill="var(--border)"/>
              <rect x="5" y="13" width="18" height="1.5" rx="0.75" fill="var(--border-subtle)"/>
              <rect x="5" y="17" width="15" height="1.5" rx="0.75" fill="var(--border-subtle)"/>
              <rect x="5" y="21" width="17" height="1.5" rx="0.75" fill="var(--border-subtle)"/>
              <path d="M19 1v8h8" fill="none" stroke="var(--border)" stroke-width="1.5"/>
            </svg>
            <span>논문 PDF</span>
          </div>

          <!-- Arrow -->
          <div class="visual-arrow" aria-hidden="true">
            <svg width="36" height="16" viewBox="0 0 36 16" fill="none">
              <path d="M2 8h28M24 3l6 5-6 5" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>

          <!-- Output label -->
          <div class="visual-label visual-label--output">
            <span>카드뉴스 8장</span>
          </div>
        </div>

      </div>
    </section>

    <!-- ─── How It Works ────────────────────────────── -->
    <section class="section section--subtle" id="how-it-works" aria-labelledby="hiw-title">
      <div class="container">
        <h2 id="hiw-title" class="section__title reveal">세 단계면 충분합니다</h2>

        <ol class="steps">
          <li class="step reveal reveal-delay-1">
            <div class="step__num" aria-hidden="true">1</div>
            <div class="step__content">
              <h3 class="step__title">논문 업로드</h3>
              <p class="step__desc">
                연구 논문 PDF를 올리고 카드 장 수를 선택하세요.
                별도 입력 없이 원문만으로 진행됩니다.
              </p>
            </div>
          </li>
          <li class="step reveal reveal-delay-2">
            <div class="step__num" aria-hidden="true">2</div>
            <div class="step__content">
              <h3 class="step__title">AI 자동 분석</h3>
              <p class="step__desc">
                AI가 논문의 연구 목적, 방법론, 핵심 수치, 결론을 원문에서 직접 추출합니다.
                수치가 포함된 모든 항목에는 출처(섹션명, 페이지)가 자동으로 표기됩니다.
              </p>
            </div>
          </li>
          <li class="step reveal reveal-delay-3">
            <div class="step__num" aria-hidden="true">3</div>
            <div class="step__content">
              <h3 class="step__title">편집 후 내보내기</h3>
              <p class="step__desc">
                카드 에디터에서 문구와 이미지를 수정하세요.
                완료하면 1080×1080 PNG 파일을 한 번에 내보냅니다.
              </p>
            </div>
          </li>
        </ol>
      </div>
    </section>

    <!-- ─── Features ────────────────────────────────── -->
    <section class="section section--surface" id="features" aria-labelledby="feat-title">
      <div class="container">
        <h2 id="feat-title" class="section__title reveal">연구 내용을 그대로 전달합니다</h2>

        <div class="features__grid">
          <article class="feature feature--wide reveal">
            <div class="feature__num" aria-hidden="true">01</div>
            <div>
              <h3 class="feature__title">원문 기반 추출</h3>
              <p class="feature__desc">
                모든 수치와 주장은 논문 원문에서만 가져옵니다.
                AI가 내용을 임의로 추가하거나 바꾸지 않습니다.
              </p>
            </div>
          </article>

          <article class="feature reveal reveal-delay-1">
            <div class="feature__num" aria-hidden="true">02</div>
            <div>
              <h3 class="feature__title">신뢰도 표시</h3>
              <p class="feature__desc">
                추출된 각 항목에 신뢰도(높음·보통·낮음)와 검토 필요 여부가 표시됩니다.
                검토가 필요한 항목이 남아있으면 내보내기 버튼이 잠깁니다.
              </p>
            </div>
          </article>

          <article class="feature reveal reveal-delay-2">
            <div class="feature__num" aria-hidden="true">03</div>
            <div>
              <h3 class="feature__title">가변 카드 구조</h3>
              <p class="feature__desc">
                논문 분량과 내용에 따라 3장에서 15장까지 자유롭게 구성합니다.
                표지, 문제 제기, 연구 방법, 결과, 마무리 등 12가지 슬라이드 유형을 지원합니다.
              </p>
            </div>
          </article>

          <article class="feature reveal reveal-delay-1">
            <div class="feature__num" aria-hidden="true">04</div>
            <div>
              <h3 class="feature__title">카드 에디터</h3>
              <p class="feature__desc">
                생성된 카드를 브라우저에서 바로 수정할 수 있습니다.
                5초 자동저장으로 작업 내용이 유지됩니다.
              </p>
            </div>
          </article>

          <article class="feature reveal reveal-delay-2">
            <div class="feature__num" aria-hidden="true">05</div>
            <div>
              <h3 class="feature__title">고해상도 내보내기</h3>
              <p class="feature__desc">
                편집 완료 후 1080×1080 PNG를 ZIP으로 일괄 다운로드합니다.
              </p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- ─── Target Users ────────────────────────────── -->
    <section class="section" aria-labelledby="users-title">
      <div class="container">
        <h2 id="users-title" class="section__title reveal">이런 분들을 위해 만들었습니다</h2>

        <ul class="users__list" role="list">
          <li class="user-item reveal reveal-delay-1">
            <span class="user-item__marker" aria-hidden="true">→</span>
            <p>연구 성과를 SNS나 기관 홈페이지에 올려야 하는 <strong>연구원</strong></p>
          </li>
          <li class="user-item reveal reveal-delay-2">
            <span class="user-item__marker" aria-hidden="true">→</span>
            <p>논문 내용을 대중 언어로 바꿔야 하는 <strong>홍보·커뮤니케이션 담당자</strong></p>
          </li>
          <li class="user-item reveal reveal-delay-3">
            <span class="user-item__marker" aria-hidden="true">→</span>
            <p>다수의 논문을 정기적으로 카드뉴스로 제작해야 하는 <strong>연구소·학술기관 팀</strong></p>
          </li>
        </ul>
      </div>
    </section>

    <!-- ─── Trust Points ────────────────────────────── -->
    <section class="section section--subtle" aria-labelledby="trust-title">
      <div class="container">
        <h2 id="trust-title" class="section__title reveal">정확성을 설계에 넣었습니다</h2>

        <div class="trust__grid">
          <article class="trust-item reveal reveal-delay-1">
            <h3 class="trust-item__title">수치에 출처 자동 표기</h3>
            <p class="trust-item__desc">모든 숫자에 섹션명과 페이지가 함께 표시됩니다.</p>
          </article>
          <article class="trust-item reveal reveal-delay-2">
            <h3 class="trust-item__title">위험 항목 경고</h3>
            <p class="trust-item__desc">검증이 불확실한 항목은 에디터에서 명확히 표시됩니다.</p>
          </article>
          <article class="trust-item reveal reveal-delay-3">
            <h3 class="trust-item__title">AI 결과 강제 없음</h3>
            <p class="trust-item__desc">생성된 모든 내용은 에디터에서 수정하거나 삭제할 수 있습니다.</p>
          </article>
          <article class="trust-item reveal reveal-delay-4">
            <h3 class="trust-item__title">프로젝트 이력 보존</h3>
            <p class="trust-item__desc">변환한 논문과 작업 내역은 대시보드에서 언제든 다시 확인할 수 있습니다.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- ─── Signup / CTA ─────────────────────────────── -->
    <section class="section section--dark cta-section" id="signup" aria-labelledby="cta-title">
      <div class="container cta__inner">
        <h2 id="cta-title" class="cta__title reveal">지금 논문을 업로드해 보세요.</h2>
        <p class="cta__sub reveal reveal-delay-1">현재 무료 베타 운영 중입니다. 이메일을 남기시면 바로 접속 링크를 보내드립니다.</p>

        <form
          class="signup-form reveal reveal-delay-2"
          id="signup-form"
          novalidate
          aria-label="베타 참여 신청"
        >
          <div class="signup-row">
            <label for="signup-email" class="visually-hidden">이메일 주소</label>
            <input
              type="email"
              id="signup-email"
              name="email"
              class="signup-input"
              placeholder="연구소 또는 학교 이메일"
              required
              autocomplete="email"
              aria-required="true"
              aria-describedby="signup-hint"
            />
            <button type="submit" class="btn btn-white btn-lg">무료로 시작하기</button>
          </div>
          <p id="signup-hint" class="signup-hint">회원가입 없이 바로 사용 가능 · 스팸 없음 · 언제든지 취소</p>
          <p class="signup-error" id="signup-error" role="alert" aria-live="polite" hidden></p>
        </form>

        <div class="signup-success" id="signup-success" hidden aria-live="polite">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
            <path d="M6 10l3 3 5-5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span id="signup-success-msg"></span>
        </div>
      </div>
    </section>

  </main>

  <!-- ─── Footer ──────────────────────────────────── -->
  <footer class="footer" role="contentinfo">
    <div class="container footer__inner">
      <p class="footer__logo">PolyInsight</p>
      <div class="footer__links">
        <a href="#">개인정보 처리방침</a>
        <a href="#">이용약관</a>
        <a href="#">문의하기</a>
      </div>
      <p class="footer__copy">&copy; 2026 PolyInsight. All rights reserved.</p>
    </div>
  </footer>

  <UploadModal />
</Layout>

<style is:global>

  /* ─── Nav ────────────────────────────────────────── */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--nav-h);
    background: var(--bg);
    background: color-mix(in oklch, var(--bg) 82%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid transparent;
    transition: border-color 220ms ease, background 220ms ease;
  }
  .nav.is-scrolled { border-bottom-color: var(--border-subtle); }

  .nav__inner {
    height: 100%;
    display: flex;
    align-items: center;
    gap: var(--s8);
  }

  .nav__logo {
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--text-1);
    margin-right: auto;
    flex-shrink: 0;
  }
  .nav__logo span { color: var(--accent); }

  .nav__links {
    display: flex;
    align-items: center;
    gap: var(--s6);
  }
  .nav__links a {
    font-size: var(--t-sm);
    color: var(--text-2);
    transition: color 140ms ease;
  }
  .nav__links a:hover { color: var(--text-1); }

  .nav__actions {
    display: flex;
    align-items: center;
    gap: var(--s2);
    flex-shrink: 0;
  }

  .nav__toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--s2);
    color: var(--text-1);
    border-radius: var(--radius-sm);
    transition: background 140ms;
  }
  .nav__toggle:hover { background: var(--bg-subtle); }
  .nav__toggle:focus-visible { outline: 2.5px solid var(--accent); outline-offset: 2px; }

  .nav__mobile {
    display: none;
    flex-direction: column;
    gap: var(--s4);
    padding: var(--s4) var(--gutter) var(--s6);
    background: var(--bg);
    border-bottom: 1px solid var(--border-subtle);
  }
  .nav__mobile nav {
    display: flex;
    flex-direction: column;
    gap: var(--s1);
  }
  .nav__mobile nav a {
    padding: var(--s3) var(--s2);
    font-size: var(--t-base);
    color: var(--text-2);
    border-radius: var(--radius-sm);
    transition: color 140ms, background 140ms;
  }
  .nav__mobile nav a:hover { color: var(--text-1); background: var(--bg-subtle); }
  .nav__mobile .mobile-login { border-top: 1px solid var(--border-subtle); margin-top: var(--s2); padding-top: var(--s4); }
  .nav__mobile.is-open { display: flex; }

  @media (max-width: 768px) {
    .nav__links, .btn-login { display: none; }
    .nav__toggle { display: flex; }
  }

  /* ─── Hero ───────────────────────────────────────── */
  .hero {
    padding-top: calc(var(--nav-h) + clamp(var(--s12), 7vw, var(--s32)));
    padding-bottom: clamp(var(--s16), 8vw, var(--s32));
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(var(--s12), 6vw, var(--s32));
    align-items: center;
  }

  .hero__title {
    font-size: var(--t-hero);
    font-weight: 800;
    color: var(--text-1);
    line-height: 1.1;
    margin-bottom: var(--s6);
    letter-spacing: -0.035em;
  }

  .hero__sub {
    font-size: var(--t-lg);
    color: var(--text-2);
    line-height: 1.75;
    max-width: 52ch;
    margin-bottom: var(--s8);
  }

  .hero__actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--s4);
  }

  .hero__note {
    display: flex;
    align-items: center;
    gap: var(--s2);
    font-size: var(--t-sm);
    color: var(--text-3);
  }

  /* ─── Card Stack Visual ──────────────────────────── */
  .hero__visual {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s6);
  }

  .card-stack {
    position: relative;
    width: min(280px, 90%);
    aspect-ratio: 1;
    margin-inline: auto;
  }

  .card-mock {
    position: absolute;
    inset: 0;
    background: white;
    border-radius: var(--radius-lg);
    box-shadow:
      0 1px 3px oklch(0% 0 0 / 0.06),
      0 8px 24px oklch(0% 0 0 / 0.08),
      0 20px 48px oklch(0% 0 0 / 0.06);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .card-mock--3 {
    transform: rotate(-6deg) translateY(8px) scale(0.92);
    opacity: 0.45;
    z-index: 1;
  }
  .card-mock--2 {
    transform: rotate(-2.5deg) translateY(4px) scale(0.96);
    opacity: 0.7;
    z-index: 2;
  }
  .card-mock--1 {
    transform: rotate(0deg);
    z-index: 3;
  }

  .card-mock__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--s3) var(--s4);
