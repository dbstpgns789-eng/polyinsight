---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'PolyInsight — 논문 PDF 하나로, 카드뉴스 완성',
  description = '학술 논문을 업로드하면 AI가 원문에서 핵심 내용을 직접 추출해 카드뉴스를 만듭니다. 수치와 근거는 논문 그대로, 편집 가능한 형태로 제공됩니다.',
} = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic.min.css"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* ─── Design Tokens ─────────────────────────────── */
  :root {
    /* Accent — deep forest green (not SaaS blue/purple) */
    --accent:         oklch(38% 0.14 152);
    --accent-hover:   oklch(32% 0.14 152);
    --accent-subtle:  oklch(94% 0.035 152);
    --accent-faint:   oklch(97% 0.018 152);

    /* Neutrals — tinted toward brand hue for cohesion */
    --bg:             oklch(98% 0.005 152);
    --bg-subtle:      oklch(95.5% 0.009 152);
    --surface:        oklch(99.8% 0.002 152);
    --border:         oklch(89% 0.012 152);
    --border-subtle:  oklch(93.5% 0.007 152);

    /* Text */
    --text-1:  oklch(16% 0.008 152);
    --text-2:  oklch(44% 0.012 152);
    --text-3:  oklch(63% 0.008 152);

    /* Dark section */
    --dark-bg:   oklch(14% 0.04 152);
    --dark-bg-2: oklch(19% 0.04 152);

    /* Spacing (4pt base) */
    --s1:  4px;
    --s2:  8px;
    --s3:  12px;
    --s4:  16px;
    --s6:  24px;
    --s8:  32px;
    --s10: 40px;
    --s12: 48px;
    --s16: 64px;
    --s24: 96px;
    --s32: 128px;

    /* Typography scale */
    --t-xs:      0.75rem;
    --t-sm:      0.875rem;
    --t-base:    1rem;
    --t-lg:      1.125rem;
    --t-xl:      1.375rem;
    --t-2xl:     1.875rem;
    --t-display: clamp(1.875rem, 3vw + 0.75rem, 2.875rem);
    --t-hero:    clamp(2.625rem, 5.5vw + 0.75rem, 5rem);

    /* Risk severity palette */
    --risk-critical:         oklch(40% 0.16 25);
    --risk-critical-hover:   oklch(34% 0.16 25);
    --risk-critical-faint:   oklch(97% 0.025 25);
    --risk-critical-subtle:  oklch(94% 0.04 25);
    --risk-critical-border:  oklch(78% 0.1 25);
    --risk-critical-field-bg: oklch(99% 0.015 25);

    --risk-high:             oklch(42% 0.18 50);
    --risk-high-faint:       oklch(97% 0.03 50);
    --risk-high-subtle:      oklch(95% 0.05 50);
    --risk-high-border:      oklch(82% 0.1 50);
    --risk-high-field-bg:    oklch(99% 0.015 55);

    --risk-medium:           oklch(45% 0.14 80);
    --risk-medium-faint:     oklch(98% 0.02 80);
    --risk-medium-subtle:    oklch(95% 0.05 80);
    --risk-medium-border:    oklch(85% 0.08 80);

    --risk-ok:               oklch(34% 0.12 152);
    --risk-ok-bg:            oklch(93% 0.05 152);
    --risk-ok-border:        oklch(80% 0.08 152);

    /* Status — info (saving/syncing) */
    --status-saving-bg:      oklch(95% 0.03 200);
    --status-saving:         oklch(38% 0.1  200);

    /* Overlay */
    --overlay-bg:            oklch(14% 0.04 152 / 0.7);
    --overlay-scrim:         oklch(8% 0.01 152 / 0.55);

    /* Risk borders (lighter than badge bg) */
    --risk-critical-line:    oklch(86% 0.07 25);
    --risk-high-line:        oklch(86% 0.08 52);

    /* On-dark surface (white with opacity — toast, dark overlays) */
    --on-dark-border:        oklch(100% 0 0 / 0.35);
    --on-dark-mid:           oklch(100% 0 0 / 0.55);
    --on-dark-hover:         oklch(100% 0 0 / 0.12);

    /* Shadows — brand-tinted (never pure black) */
    --shadow-sm:  0 2px 8px  oklch(8% 0.01 152 / 0.07);
    --shadow-md:  0 12px 32px oklch(8% 0.01 152 / 0.10);
    --shadow-lg:  0 16px 48px oklch(8% 0.01 152 / 0.18);

    /* Other */
    --radius-sm: 6px;
    --radius-md: 10px;
    --radius-lg: 16px;
    --nav-h:     68px;
    --max-w:     1120px;
    --gutter:    clamp(var(--s6), 5vw, var(--s16));
    --section-py: clamp(var(--s16), 8vw, var(--s32));
  }

  /* ─── Reset ─────────────────────────────────────── */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    -webkit-text-size-adjust: 100%;
  }

  body {
    font-family: "Pretendard Variable", Pretendard,
      -apple-system, BlinkMacSystemFont, "Apple SD Gothic Neo",
      "Segoe UI", system-ui, sans-serif;
    font-size: var(--t-base);
    line-height: 1.7;
    color: var(--text-1);
    background: var(--bg);
    font-optical-sizing: auto;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    font-kerning: normal;
    word-break: keep-all;
    overflow-wrap: break-word;
  }

  img, picture, video, canvas, svg { display: block; max-width: 100%; }
  input, button, textarea, select { font: inherit; }
  a { color: inherit; text-decoration: none; }
  ul, ol { list-style: none; }
  p { text-wrap: pretty; }
  h1, h2, h3, h4, h5 {
    text-wrap: balance;
    line-height: 1.2;
    letter-spacing: -0.025em;
    font-kerning: normal;
  }

  /* ─── Layout ─────────────────────────────────────── */
  .container {
    width: 100%;
    max-width: var(--max-w);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ─── Buttons ────────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--s2);
    padding: 0.6em 1.5em;
    border-radius: var(--radius-md);
    font-weight: 500;
    font-size: var(--t-base);
    line-height: 1.4;
    cursor: pointer;
    border: 1.5px solid transparent;
    transition:
      background 160ms ease,
      color 160ms ease,
      border-color 160ms ease,
      transform 80ms ease;
    white-space: nowrap;
    user-select: none;
  }
  .btn:active { transform: translateY(1px); }
  .btn:disabled { opacity: 0.55; cursor: not-allowed; transform: none; }

  .btn-primary {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }
  .btn-primary:hover { background: var(--accent-hover); border-color: var(--accent-hover); }
  .btn-primary:focus-visible { outline: 2.5px solid var(--accent); outline-offset: 3px; }

  .btn-outline {
    background: transparent;
    color: var(--text-1);
    border-color: var(--border);
  }
  .btn-outline:hover { border-color: var(--text-2); background: var(--bg-subtle); }
  .btn-outline:focus-visible { outline: 2.5px solid var(--accent); outline-offset: 3px; }

  .btn-ghost {
    background: transparent;
    color: var(--text-2);
    border-color: transparent;
  }
  .btn-ghost:hover { color: var(--text-1); background: var(--bg-subtle); }
  .btn-ghost:focus-visible { outline: 2.5px solid var(--accent); outline-offset: 3px; }

  .btn-white {
    background: #fff;
    color: var(--accent);
    border-color: #fff;
    font-weight: 600;
  }
  .btn-white:hover { background: oklch(96% 0.02 152); }
  .btn-white:focus-visible { outline: 2.5px solid #fff; outline-offset: 3px; }

  .btn-lg {
    padding: 0.8em 2.25em;
    font-size: var(--t-lg);
    border-radius: var(--radius-lg);
  }

  /* ─── Section helpers ────────────────────────────── */
  .section {
    padding-block: var(--section-py);
  }
  .section--subtle { background: var(--bg-subtle); }
  .section--surface { background: var(--surface); }
  .section--dark { background: var(--dark-bg); color: oklch(92% 0.008 152); }

  .eyebrow {
    display: inline-block;
    font-size: var(--t-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: var(--s4);
  }

  /* ─── Scroll reveal ──────────────────────────────── */
  @media (prefers-reduced-motion: no-preference) {
    .reveal {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 550ms ease, transform 550ms ease;
    }
    .reveal.is-visible { opacity: 1; transform: none; }
    .reveal-delay-1 { transition-delay: 80ms; }
    .reveal-delay-2 { transition-delay: 160ms; }
    .reveal-delay-3 { transition-delay: 240ms; }
    .reveal-delay-4 { transition-delay: 320ms; }
  }
</style>
